{
  "name": "Lumivara — intake-sms",
  "_notes": [
    "Reference template for Phase 2 of the admin portal.",
    "Import into n8n, then: (1) set Twilio credential on 'Twilio reply',",
    "(2) set Anthropic credential on 'Structure with Claude',",
    "(3) set GitHub credential on 'Create GitHub Issue'.",
    "Activate the workflow and copy the webhook URL into the Twilio number's 'A message comes in' webhook (HTTP POST).",
    "Allow-list sender phone numbers by editing the 'Allow-list phone' node — defaults are placeholders.",
    "Twilio posts application/x-www-form-urlencoded; the payload is in the form body, not JSON, hence no HMAC verification node — Twilio's own X-Twilio-Signature header is the auth boundary and should be enforced via the Webhook node's 'Twilio Signature' option."
  ],
  "nodes": [
    {
      "id": "webhook-in",
      "name": "Twilio webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 320],
      "parameters": {
        "httpMethod": "POST",
        "path": "lumivara/intake/sms",
        "responseMode": "responseNode",
        "options": { "rawBody": false }
      }
    },
    {
      "id": "allow-list-phone",
      "name": "Allow-list phone",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 320],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "combinator": "or",
          "conditions": [
            {
              "leftValue": "={{ $json.body.From }}",
              "rightValue": "+15555550100",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      }
    },
    {
      "id": "structure-claude",
      "name": "Structure with Claude",
      "type": "n8n-nodes-base.anthropic",
      "typeVersion": 1,
      "position": [700, 320],
      "parameters": {
        "model": "claude-opus-4-7",
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "Restructure this client SMS as a GitHub issue.\n\nReturn JSON with keys: title (<=80 chars), body_md (Markdown with sections: 'What the client said' (verbatim SMS), 'Acceptance criteria' (checklist)).\n\nFrom: {{ $json.body.From }}\nMessage:\n{{ $json.body.Body }}"
            }
          ]
        },
        "options": { "responseFormat": "json_object", "maxTokens": 1024 }
      }
    },
    {
      "id": "create-issue",
      "name": "Create GitHub Issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [940, 320],
      "parameters": {
        "resource": "issue",
        "operation": "create",
        "owner": "palimkarakshay",
        "repository": "lumivara-site",
        "title": "={{ $json.title }}",
        "body": "={{ $json.body_md }}\n\n<!-- lumivara:source=sms -->\n<!-- lumivara:reply-to={{ $node[\"Twilio webhook\"].json.body.From }} -->\n\n---\n**Original SMS (verbatim):**\n\n> {{ ($node[\"Twilio webhook\"].json.body.Body || '').replace(/\\n/g, '\\n> ') }}",
        "labels": ["source/sms", "client/lumivara", "status/triage"]
      }
    },
    {
      "id": "twilio-reply",
      "name": "Twilio reply",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1180, 320],
      "parameters": {
        "operation": "send",
        "from": "={{ $node[\"Twilio webhook\"].json.body.To }}",
        "to": "={{ $node[\"Twilio webhook\"].json.body.From }}",
        "message": "Thanks — we got it. Track progress: https://lumivara.ca/admin"
      }
    },
    {
      "id": "respond-200",
      "name": "Respond 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1420, 320],
      "parameters": {
        "respondWith": "text",
        "responseCode": 200,
        "responseBody": "<Response/>",
        "options": { "responseHeaders": { "entries": [{ "name": "Content-Type", "value": "application/xml" }] } }
      }
    }
  ],
  "connections": {
    "Twilio webhook": {
      "main": [[{ "node": "Allow-list phone", "type": "main", "index": 0 }]]
    },
    "Allow-list phone": {
      "main": [
        [{ "node": "Structure with Claude", "type": "main", "index": 0 }],
        [{ "node": "Respond 200", "type": "main", "index": 0 }]
      ]
    },
    "Structure with Claude": {
      "main": [[{ "node": "Create GitHub Issue", "type": "main", "index": 0 }]]
    },
    "Create GitHub Issue": {
      "main": [[{ "node": "Twilio reply", "type": "main", "index": 0 }]]
    },
    "Twilio reply": {
      "main": [[{ "node": "Respond 200", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "version": 1
  "name": "Lumivara · Admin · Intake (sms)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "lumivara-intake-sms",
        "responseMode": "responseNode"
      },
      "name": "Twilio webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "functionCode": "const allowed = ($env['INTAKE_ALLOW_PHONES'] || '').split(',').map(s => s.trim()).filter(Boolean);\nconst from = $input.first().json.From || $input.first().json.from || '';\nif (allowed.length && !allowed.includes(from)) throw new Error('phone-not-allowlisted');\nconst body = $input.first().json.Body || $input.first().json.body || '';\nconst clientSlug = $env['INTAKE_DEFAULT_CLIENT'] || 'lumivara';\nreturn [{ json: { title: body.slice(0, 80), body, replyTo: from, clientSlug } }];"
      },
      "name": "Allow-list + normalise",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [400, 300]
    },
    {
      "parameters": {
        "model": "claude-opus-4-7",
        "messages": [
          {
            "role": "system",
            "content": "You are an issue-structurer for the Lumivara admin portal. Take the client's raw SMS and produce JSON with {title, body, suggestedLabels[]}. SMS bodies can be terse — extrapolate intent but always quote the raw text under '## Original request'."
          },
          { "role": "user", "content": "={{ $json.body }}" }
        ]
      },
      "name": "Structure with Claude",
      "type": "n8n-nodes-base.anthropic",
      "typeVersion": 1,
      "position": [620, 300]
    },
    {
      "parameters": {
        "operation": "create",
        "owner": "={{ $env['GITHUB_REPO'].split('/')[0] }}",
        "repository": "={{ $env['GITHUB_REPO'].split('/')[1] }}",
        "title": "={{ $json.title }}",
        "body": "={{ $json.body }}\\n\\n<!-- source=sms client={{ $('Allow-list + normalise').item.json.clientSlug }} reply={{ $('Allow-list + normalise').item.json.replyTo }} -->",
        "labels": "=source/sms,client/{{ $('Allow-list + normalise').item.json.clientSlug }},status/triage"
      },
      "name": "Create GitHub issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [840, 300]
    },
    {
      "parameters": {
        "from": "={{ $env['TWILIO_FROM_NUMBER'] }}",
        "to": "={{ $('Allow-list + normalise').item.json.replyTo }}",
        "message": "Got it. Track status: https://{{ $env['LUMIVARA_DOMAIN'] }}/admin/client/{{ $('Allow-list + normalise').item.json.clientSlug }}/request/{{ $json.number }}"
      },
      "name": "Twilio reply",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1060, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<Response></Response>",
        "options": { "responseHeaders": { "entries": [{ "name": "Content-Type", "value": "text/xml" }] } }
      },
      "name": "Empty TwiML ACK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1280, 300]
    }
  ],
  "connections": {
    "Twilio webhook": { "main": [[{ "node": "Allow-list + normalise", "type": "main", "index": 0 }]] },
    "Allow-list + normalise": { "main": [[{ "node": "Structure with Claude", "type": "main", "index": 0 }]] },
    "Structure with Claude": { "main": [[{ "node": "Create GitHub issue", "type": "main", "index": 0 }]] },
    "Create GitHub issue": { "main": [[{ "node": "Twilio reply", "type": "main", "index": 0 }]] },
    "Twilio reply": { "main": [[{ "node": "Empty TwiML ACK", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false,
  "tags": ["lumivara", "admin-portal", "intake"]
}
