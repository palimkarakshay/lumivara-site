# Copy this file to .env.local and fill in real values before running.
# None of these are required for local dev — defaults work offline.

# ─── Public site config ────────────────────────────────────────────
# Cal.com booking link (leave default to use a placeholder).
NEXT_PUBLIC_CAL_LINK=https://cal.com/lumivara/discovery

# Public site URL — used for OG images, canonical URLs, sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Per-build client tier (starter | growth | scale). Set per Vercel
# project so each client gets the right feature set without code
# changes. Lumivara mothership runs scale.
NEXT_PUBLIC_LUMIVARA_TIER=scale

# ─── Marketing email ───────────────────────────────────────────────
# Resend API key — only required once real email sending is enabled.
# Get one at https://resend.com
RESEND_API_KEY=

# Destination email for contact form submissions.
CONTACT_EMAIL=hello@lumivara.ca

# ─── Auth.js v5 (admin sign-in) ────────────────────────────────────
# 32-byte JWT signing key. Generate: openssl rand -base64 32
AUTH_SECRET=

# Resend API key for magic-link sign-in. May be the same as RESEND_API_KEY.
AUTH_RESEND_KEY=

# Google OAuth client (https://console.cloud.google.com).
# Authorised redirect: https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra (https://entra.microsoft.com → App registrations).
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Optional CSV fallback added to the hard-coded operator allow-list.
ADMIN_ALLOWLIST_EMAILS=

# ─── Mothership (operator) admin ───────────────────────────────────
# Repo slug "owner/name" the dashboard reads from.
GITHUB_REPO=palimkarakshay/lumivara-site
# Fine-grained PAT scoped to the repo above. Required permissions:
#   - Issues:        Read and write
#   - Pull requests: Read
#   - Actions:       Read
#   - Variables:     Read and write
#   - Metadata:      Read
GITHUB_TOKEN=

# ─── Client subset → n8n webhook bridge ────────────────────────────
# Shared HMAC secret for every Next.js → n8n call. Generate:
#   openssl rand -hex 32
# Set the SAME value in n8n's Variables panel.
N8N_HMAC_SECRET=

# Webhook URL for the intake-web workflow (Phase 2, issue #92).
N8N_INTAKE_WEBHOOK_URL=

# Webhook URL for the client-input-record workflow (Phase 4, issue #94).
N8N_DECISION_WEBHOOK_URL=

# Webhook URL for the FIRST webhook node of the deploy-confirmed
# workflow (Phase 5, issue #95). The second webhook in that workflow
# is the one Vercel posts deployment events to.
N8N_DEPLOY_WEBHOOK_URL=

# ─── Vercel REST API (preview lookups) ─────────────────────────────
# Read-only token scoped to the project. Used by /admin/client/.../preview
# and the request detail page to find the latest preview deploy URL.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# Only set if your project lives under a Vercel team.
VERCEL_TEAM_ID=

# ─── Per-client deploy hooks ───────────────────────────────────────
# Vercel project → Settings → Deploy Hooks → create one per client.
# n8n's deploy-confirmed workflow reads VERCEL_DEPLOY_HOOK_<UPPERSLUG>.
VERCEL_DEPLOY_HOOK_LUMIVARA=
